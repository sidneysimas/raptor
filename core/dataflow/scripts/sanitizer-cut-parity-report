#!/usr/bin/env python3
"""CLI shim for the sanitizer-cut parity baseline report generator.

Prints the markdown report to stdout. Run via ``bin/raptor`` (which
sets ``CLAUDECODE``) or with ``_RAPTOR_TRUSTED=1`` for direct
invocation in tests / regeneration.

Set ``RAPTOR_SANITIZER_CUT=1`` so the value-bound gate is consulted
(the baseline's sanitizer-cut fixtures need the flag on to suppress).
"""
import os
import sys
from pathlib import Path

# ─── trust-marker check (do not import; inline by design) ───
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[3]))

from core.dataflow.sanitizer_cut_parity_report import (  # noqa: E402
    render_baseline_report,
)

sys.stdout.write(render_baseline_report() + "\n")
sys.exit(0)
